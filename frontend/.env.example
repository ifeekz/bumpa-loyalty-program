# API base URL — leave as /api to use the Vite dev proxy (recommended for local dev)
# In production set this to your actual backend URL:
# VITE_API_URL=https://api.yourapp.com/api
VITE_API_URL=/api

# Dev proxy target — Vite rewrites /api/* to this URL during local dev.
# Leave empty if your backend runs on the same origin or you handle CORS directly.
VITE_API_PROXY_TARGET=http://localhost:8000
