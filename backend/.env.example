APP_NAME="Loyalty Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=loyalty_db
DB_USERNAME=loyalty_user
DB_PASSWORD=secret

# Redis
CACHE_DRIVER=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Queue + Cache
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# JWT
# Generate with: php artisan jwt:secret
JWT_SECRET=                     # REQUIRED — run jwt:secret after install
JWT_ALGO=HS256
JWT_TTL=60                      # Access token TTL in minutes
JWT_REFRESH_TTL=20160           # Refresh window: 2 weeks
JWT_BLACKLIST_ENABLED=true      # Enables stateless logout via Redis blacklist

# Paystack
PAYSTACK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYSTACK_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYSTACK_BASE_URL=https://api.paystack.co

# Loyalty Program Config
LOYALTY_CASHBACK_PERCENT=5

# For CORS
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
